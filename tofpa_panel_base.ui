<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>TOFPADockWidgetBase</class>
 <widget class="QDockWidget" name="TOFPADockWidgetBase">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>300</width>
    <height>500</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>TOFPA</string>
  </property>
  <widget class="QWidget" name="dockWidgetContents">
   <layout class="QVBoxLayout" name="verticalLayout">
    <item>
     <widget class="QLabel" name="titleLabel">
      <property name="text">
       <string>TOFPA - Takeoff and Final Approach Analysis</string>
      </property>
      <property name="alignment">
       <set>Qt::AlignCenter</set>
      </property>
     </widget>
    </item>
    <item>
     <widget class="QGroupBox" name="layersGroup">
      <property name="title">
       <string>Input Layers</string>
      </property>
      <layout class="QFormLayout" name="formLayout">
       <item row="0" column="0">
        <widget class="QLabel" name="runwayLabel">
         <property name="text">
          <string>Runway Layer:</string>
         </property>
         <property name="toolTip">
          <string>Vector layer containing the runway centreline (LineString geometry)</string>
         </property>
        </widget>
       </item>
       <item row="0" column="1">
        <widget class="QgsMapLayerComboBox" name="runwayLayerCombo"/>
       </item>
       <item row="1" column="0">
        <widget class="QLabel" name="thresholdLabel">
         <property name="text">
          <string>Threshold Layer:</string>
         </property>
         <property name="toolTip">
          <string>Vector layer containing the runway threshold point (Point geometry)</string>
         </property>
        </widget>
       </item>
       <item row="1" column="1">
        <widget class="QgsMapLayerComboBox" name="thresholdLayerCombo"/>
       </item>
       <item row="2" column="0" colspan="2">
        <widget class="QCheckBox" name="useSelectedFeatureCheckBox">
         <property name="text">
          <string>Use selected features only</string>
         </property>
         <property name="toolTip">
          <string>When checked, only the currently selected feature from each layer is used</string>
         </property>
        </widget>
       </item>
       <item row="3" column="0" colspan="2">
        <widget class="QCheckBox" name="includeObstaclesCheckBox">
         <property name="text">
          <string>Include survey obstacles analysis</string>
         </property>
         <property name="toolTip">
          <string>Enable ICAO obstacle analysis to identify critical obstacles within the TOFPA surface</string>
         </property>
        </widget>
       </item>
      </layout>
     </widget>
    </item>
    <item>
     <widget class="QGroupBox" name="paramsGroup">
      <property name="title">
       <string>Surface Parameters</string>
      </property>
      <layout class="QFormLayout" name="formLayout_2">
       <item row="0" column="0">
        <widget class="QLabel" name="initialWidthLabel">
         <property name="text">
          <string>Initial Width (m):</string>
         </property>
        </widget>
       </item>
       <item row="0" column="1">
        <widget class="QDoubleSpinBox" name="initialWidthSpin">
         <property name="toolTip">
          <string>Initial width of the TOFPA surface at the DER (ICAO Doc 8168 Vol I §3.1.3). Typical: 180 m</string>
         </property>
         <property name="minimum">
          <double>0.000000000000000</double>
         </property>
         <property name="maximum">
          <double>10000.000000000000000</double>
         </property>
         <property name="decimals">
          <number>8</number>
         </property>
         <property name="value">
          <double>180.000000000000000</double>
         </property>
         <property name="suffix">
          <string> m</string>
         </property>
        </widget>
       </item>
       <item row="1" column="0">
        <widget class="QLabel" name="maxWidthLabel">
         <property name="text">
          <string>Maximum Width (m):</string>
         </property>
        </widget>
       </item>
       <item row="1" column="1">
        <widget class="QDoubleSpinBox" name="maxWidthSpin">
         <property name="toolTip">
          <string>Maximum width of the TOFPA surface at the end of the climb. Typical: 1800 m</string>
         </property>
         <property name="minimum">
          <double>0.000000000000000</double>
         </property>
         <property name="maximum">
          <double>100000.000000000000000</double>
         </property>
         <property name="decimals">
          <number>8</number>
         </property>
         <property name="value">
          <double>1800.000000000000000</double>
         </property>
         <property name="suffix">
          <string> m</string>
         </property>
        </widget>
       </item>
       <item row="2" column="0">
        <widget class="QLabel" name="clearwayLabel">
         <property name="text">
          <string>Clearway Length (m):</string>
         </property>
        </widget>
       </item>
       <item row="2" column="1">
        <widget class="QDoubleSpinBox" name="clearwayLengthSpin">
         <property name="toolTip">
          <string>Clearway (CWY) length before the DER. Set to 0 if no clearway exists (ICAO Doc 8168 Vol I §3.1.2)</string>
         </property>
         <property name="minimum">
          <double>0.000000000000000</double>
         </property>
         <property name="maximum">
          <double>10000.000000000000000</double>
         </property>
         <property name="decimals">
          <number>8</number>
         </property>
         <property name="suffix">
          <string> m</string>
         </property>
        </widget>
       </item>
       <item row="3" column="0">
        <widget class="QLabel" name="initElevLabel">
         <property name="text">
          <string>THR Elevation (m):</string>
         </property>
        </widget>
       </item>
       <item row="3" column="1">
        <widget class="QDoubleSpinBox" name="initialElevationSpin">
         <property name="toolTip">
          <string>Elevation of the runway threshold (Z0). Used as the elevation of the threshold reference point (metres above MSL).</string>
         </property>
         <property name="minimum">
          <double>-1000.000000000000000</double>
         </property>
         <property name="maximum">
          <double>10000.000000000000000</double>
         </property>
         <property name="decimals">
          <number>8</number>
         </property>
         <property name="suffix">
          <string> m</string>
         </property>
        </widget>
       </item>
       <item row="4" column="0">
        <widget class="QLabel" name="endElevLabel">
         <property name="text">
          <string>DER Elevation (m):</string>
         </property>
        </widget>
       </item>       <item row="4" column="1">
        <widget class="QDoubleSpinBox" name="endElevationSpin">
         <property name="toolTip">
          <string>Elevation at the Departure End of the Runway (ZE). The TOFPA OCS surface starts from this elevation and climbs at 1.2% — ICAO Doc 8168 Vol I §3.1.3.</string>
         </property>
         <property name="minimum">
          <double>-1000.000000000000000</double>
         </property>
         <property name="maximum">
          <double>10000.000000000000000</double>
         </property>
         <property name="decimals">
          <number>8</number>
         </property>
         <property name="suffix">
          <string> m</string>
         </property>
        </widget>
       </item>
       <item row="5" column="0">
        <widget class="QLabel" name="directionLabel">
         <property name="text">
          <string>Runway Direction:</string>
         </property>
        </widget>
       </item>
       <item row="5" column="1">
        <widget class="QComboBox" name="directionCombo">
         <property name="toolTip">
          <string>Direction of takeoff relative to the runway feature geometry</string>
         </property>
         <item>
          <property name="text">
           <string>Takeoff toward runway end (→)</string>
          </property>
         </item>
         <item>
          <property name="text">
           <string>Takeoff toward runway start (←)</string>
          </property>
         </item>
        </widget>
       </item>
      </layout>
     </widget>
    </item>
    <item>
     <widget class="QGroupBox" name="obstaclesGroup">
      <property name="title">
       <string>Survey Obstacles Parameters</string>
      </property>
      <layout class="QFormLayout" name="formLayout_3">
       <item row="0" column="0">
        <widget class="QLabel" name="obstaclesLabel">
         <property name="text">
          <string>Obstacles Layer:</string>
         </property>
         <property name="toolTip">
          <string>Vector layer containing obstacle points or polygons to analyse</string>
         </property>
        </widget>
       </item>
       <item row="0" column="1">
        <widget class="QgsMapLayerComboBox" name="obstaclesLayerCombo"/>
       </item>
       <item row="1" column="0">
        <widget class="QLabel" name="obstacleBufferLabel">
         <property name="text">
          <string>Safety Buffer (m):</string>
         </property>
         <property name="toolTip">
          <string>Horizontal safety buffer radius around each obstacle for intersection test</string>
         </property>
        </widget>
       </item>
       <item row="1" column="1">
        <widget class="QDoubleSpinBox" name="obstacleBufferSpin">
         <property name="toolTip">
          <string>Horizontal safety buffer radius around each obstacle for intersection test</string>
         </property>
         <property name="minimum">
          <double>0.000000000000000</double>
         </property>
         <property name="maximum">
          <double>1000.000000000000000</double>
         </property>
         <property name="decimals">
          <number>2</number>
         </property>
         <property name="value">
          <double>10.00</double>
         </property>
         <property name="suffix">
          <string> m</string>
         </property>
        </widget>
       </item>
       <item row="2" column="0">
        <widget class="QLabel" name="obstacleHeightFieldLabel">
         <property name="text">
          <string>Height Field:</string>
         </property>
         <property name="toolTip">
          <string>Field in the obstacle layer that contains the obstacle height (metres)</string>
         </property>
        </widget>
       </item>
       <item row="2" column="1">
        <widget class="QComboBox" name="obstacleHeightFieldCombo">
         <property name="toolTip">
          <string>Field in the obstacle layer that contains the obstacle height (metres)</string>
         </property>
         <property name="editable">
          <bool>true</bool>
         </property>
        </widget>
       </item>
       <item row="3" column="0">
        <widget class="QLabel" name="minObstacleHeightLabel">
         <property name="text">
          <string>Min Height (m):</string>
         </property>
         <property name="toolTip">
          <string>Obstacles below this height are ignored in the analysis</string>
         </property>
        </widget>
       </item>
       <item row="3" column="1">
        <widget class="QDoubleSpinBox" name="minObstacleHeightSpin">
         <property name="toolTip">
          <string>Obstacles below this height are ignored in the analysis</string>
         </property>
         <property name="minimum">
          <double>0.000000000000000</double>
         </property>
         <property name="maximum">
          <double>1000.000000000000000</double>
         </property>
         <property name="decimals">
          <number>2</number>
         </property>
         <property name="value">
          <double>5.00</double>
         </property>
         <property name="suffix">
          <string> m</string>
         </property>
        </widget>
       </item>
       <item row="4" column="0" colspan="2">
        <widget class="QCheckBox" name="enableShadowAnalysisCheckBox">
         <property name="text">
          <string>Enable shadow analysis</string>
         </property>
         <property name="toolTip">
          <string>Analyse which critical obstacles are shadowed (hidden) by closer, taller obstacles relative to the takeoff point</string>
         </property>
        </widget>
       </item>
       <item row="5" column="0">
        <widget class="QLabel" name="shadowToleranceLabel">
         <property name="text">
          <string>Shadow Tolerance (°):</string>
         </property>
         <property name="toolTip">
          <string>Angular tolerance in degrees for shadow cone calculation (ICAO shadow analysis)</string>
         </property>
        </widget>
       </item>
       <item row="5" column="1">
        <widget class="QDoubleSpinBox" name="shadowToleranceSpin">
         <property name="toolTip">
          <string>Angular tolerance in degrees for shadow cone calculation (ICAO shadow analysis)</string>
         </property>
         <property name="minimum">
          <double>0.500000000000000</double>
         </property>
         <property name="maximum">
          <double>30.000000000000000</double>
         </property>
         <property name="decimals">
          <number>1</number>
         </property>
         <property name="value">
          <double>5.0</double>
         </property>
         <property name="suffix">
          <string>°</string>
         </property>
        </widget>
       </item>
      </layout>
     </widget>
    </item>
    <item>
     <widget class="QGroupBox" name="contoursGroup">
      <property name="title">
       <string>Contours</string>
      </property>
      <layout class="QFormLayout" name="formLayout_contours">
       <item row="0" column="0">
        <widget class="QLabel" name="contourIntervalLabel">
         <property name="text">
          <string>Contour Interval (m):</string>
         </property>
         <property name="toolTip">
          <string>Generate elevation contour lines every X metres. Set to 0 to disable. Lines are labelled with the surface elevation value.</string>
         </property>
        </widget>
       </item>
       <item row="0" column="1">
        <widget class="QSpinBox" name="contourIntervalSpin">
         <property name="toolTip">
          <string>Generate elevation contour lines every X metres. Set to 0 to disable.</string>
         </property>
         <property name="minimum">
          <number>0</number>
         </property>
         <property name="maximum">
          <number>500</number>
         </property>
         <property name="singleStep">
          <number>10</number>
         </property>
         <property name="value">
          <number>0</number>
         </property>
         <property name="suffix">
          <string> m</string>
         </property>
        </widget>
       </item>
      </layout>
